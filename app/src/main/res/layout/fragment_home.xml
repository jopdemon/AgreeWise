<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="24dp">

    <ImageView
        android:id="@+id/home_logo"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/agreewise_transparentlogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Protect Your Agreements"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="@color/text_primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/home_logo" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/user_profile"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:padding="2dp"
        android:src="@android:drawable/ic_menu_myplaces"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/CircleImageView"
        app:strokeColor="@color/brand_green"
        app:strokeWidth="2dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="User"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        app:layout_constraintEnd_toEndOf="@id/user_profile"
        app:layout_constraintStart_toStartOf="@id/user_profile"
        app:layout_constraintTop_toBottomOf="@id/user_profile" />

    <Button
        android:id="@+id/btn_contract_history"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Contract\nHistory"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        app:strokeColor="@color/border_color"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_tagline" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/card_paste"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginTop="24dp"
        android:text="Insert Text"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        app:icon="@drawable/ic_paste"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:iconTint="@color/black"
        app:strokeColor="@color/border_color"
        app:cornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/btn_contract_history" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/card_upload"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginTop="16dp"
        android:text="Upload File"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        app:icon="@drawable/ic_upload"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:iconTint="@color/black"
        app:strokeColor="@color/border_color"
        app:cornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/card_paste" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/card_scan"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginTop="16dp"
        android:text="Open Camera"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        app:icon="@drawable/ic_scan"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:iconTint="@color/black"
        app:strokeColor="@color/border_color"
        app:cornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/card_upload" />

</androidx.constraintlayout.widget.ConstraintLayout>